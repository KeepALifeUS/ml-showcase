# Order Flow Detection Configuration Example
# Copy to .env and customize for your environment

# Environment
ORDER_FLOW_ENVIRONMENT=development
ORDER_FLOW_DEBUG=true
ORDER_FLOW_LOG_LEVEL=DEBUG
ORDER_FLOW_APP_NAME=OrderFlowDetection
ORDER_FLOW_VERSION=1.0.0

# Database Configuration
ORDER_FLOW_DATABASE__HOST=localhost
ORDER_FLOW_DATABASE__PORT=5432
ORDER_FLOW_DATABASE__DATABASE=ctb3_order_flow
ORDER_FLOW_DATABASE__USERNAME=postgres
ORDER_FLOW_DATABASE__PASSWORD=your_password
ORDER_FLOW_DATABASE__POOL_SIZE=10
ORDER_FLOW_DATABASE__MAX_OVERFLOW=20

# Redis Configuration
ORDER_FLOW_REDIS__HOST=localhost
ORDER_FLOW_REDIS__PORT=6379
ORDER_FLOW_REDIS__DATABASE=0
ORDER_FLOW_REDIS__PASSWORD=
ORDER_FLOW_REDIS__MAX_CONNECTIONS=100

# Exchange Configuration (Example for Binance)
ORDER_FLOW_EXCHANGES__BINANCE__API_KEY=your_binance_api_key
ORDER_FLOW_EXCHANGES__BINANCE__API_SECRET=your_binance_api_secret
ORDER_FLOW_EXCHANGES__BINANCE__SANDBOX=true
ORDER_FLOW_EXCHANGES__BINANCE__RATE_LIMIT=1000
ORDER_FLOW_EXCHANGES__BINANCE__TIMEOUT=30

# Order Flow Analysis Settings
ORDER_FLOW_ORDER_FLOW__TICK_SIZE=0.01
ORDER_FLOW_ORDER_FLOW__DEPTH_LEVELS=20
ORDER_FLOW_ORDER_FLOW__IMBALANCE_THRESHOLD=0.7
ORDER_FLOW_ORDER_FLOW__ABSORPTION_RATIO=2.0
ORDER_FLOW_ORDER_FLOW__EXHAUSTION_THRESHOLD=0.3
ORDER_FLOW_ORDER_FLOW__UPDATE_FREQUENCY_MS=100

# Volume Profile Settings  
ORDER_FLOW_VOLUME_PROFILE__NUM_PRICE_LEVELS=100
ORDER_FLOW_VOLUME_PROFILE__VALUE_AREA_PERCENTAGE=0.68
ORDER_FLOW_VOLUME_PROFILE__POC_THRESHOLD=0.05
ORDER_FLOW_VOLUME_PROFILE__VWAP_PERIOD=1440

# Machine Learning Configuration
ORDER_FLOW_ML_MODELS__BATCH_SIZE=1024
ORDER_FLOW_ML_MODELS__LEARNING_RATE=0.001
ORDER_FLOW_ML_MODELS__EPOCHS=100
ORDER_FLOW_ML_MODELS__VALIDATION_SPLIT=0.2
ORDER_FLOW_ML_MODELS__USE_GPU=true

# Real-time Processing
ORDER_FLOW_REALTIME__WEBSOCKET_TIMEOUT=60
ORDER_FLOW_REALTIME__RECONNECT_ATTEMPTS=5
ORDER_FLOW_REALTIME__MAX_QUEUE_SIZE=10000
ORDER_FLOW_REALTIME__BUFFER_SIZE=1048576

# API Configuration
ORDER_FLOW_API__REST_HOST=0.0.0.0
ORDER_FLOW_API__REST_PORT=8000
ORDER_FLOW_API__WEBSOCKET_PORT=8001
ORDER_FLOW_API__GRPC_PORT=50051
ORDER_FLOW_API__ENABLE_CORS=true
ORDER_FLOW_API__ENABLE_DOCS=true

# Security Settings
ORDER_FLOW_JWT_SECRET_KEY=your_jwt_secret_key_change_in_production
ORDER_FLOW_JWT_ALGORITHM=HS256
ORDER_FLOW_JWT_EXPIRE_MINUTES=1440

# Monitoring and Performance
ORDER_FLOW_ENABLE_METRICS=true
ORDER_FLOW_METRICS_PORT=9090
ORDER_FLOW_MAX_CONCURRENT_REQUESTS=100
ORDER_FLOW_WORKER_THREADS=4
ORDER_FLOW_ENABLE_PROFILING=false

# Symbols to track (comma-separated)
ORDER_FLOW_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,ADAUSDT,DOTUSDT

# Directories
ORDER_FLOW_DATA_DIR=./data
ORDER_FLOW_LOGS_DIR=./logs
ORDER_FLOW_CACHE_DIR=./cache
ORDER_FLOW_TEMP_DIR=./temp