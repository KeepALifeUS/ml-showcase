# ML Fear & Greed Index - Environment Variables
# Copy this file to .env and fill in your values

# === External API Keys ===
FEAR_GREED_TWITTER_BEARER_TOKEN=
FEAR_GREED_REDDIT_CLIENT_ID=
FEAR_GREED_REDDIT_CLIENT_SECRET=
FEAR_GREED_NEWS_API_KEY=
FEAR_GREED_COINGECKO_API_KEY=
FEAR_GREED_BINANCE_API_KEY=
FEAR_GREED_BINANCE_SECRET_KEY=

# === Database Configuration ===
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=fear_greed_index
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=

# === Cache Configuration ===
REDIS_URL=redis://localhost:6379

# === Application Settings ===
FEAR_GREED_ENVIRONMENT=development
FEAR_GREED_DEBUG=false
FEAR_GREED_API_HOST=0.0.0.0
FEAR_GREED_API_PORT=8000
FEAR_GREED_API_WORKERS=4
